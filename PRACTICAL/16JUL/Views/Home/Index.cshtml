@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
   <h1 class="display-4">Welcome to Students Portal</h1>
</div>

<div>

    <style>
            /* Page Heading */
            h1 {
                text-align: center;
                margin-top: 20px;
                margin-bottom: 30px;
                font-size: 60px;
            }

            /* Table */
            table {
                width: 80%;
                margin: 30px auto;
                border-collapse: collapse;
                border: 2px solid black;
                background-color: white;
            }

            /* Header */
            th {
                border: 1px solid black;
                padding: 15px;
                font-weight: bold;
                font-size: 22px;
                background-color: #e9ecef;
                text-align: center;
            }

            /* Data */
            td {
                border: 1px solid black;
                padding: 15px;
                font-size: 20px;
                text-align: center;
            }

            /* Hover Effect */
            tr:hover {
                background-color: #f5f5f5;
            }

            /* Responsive */
            .table-container {
                display: flex;
                justify-content: center;
                margin-top: 20px;
            }
    </style>

    <table border="1" cellpadding="10">
        <tr>
           <th>ID </th>
           <th>NAME</th>
           <th>AGE</th>
           <th>COURSE</th>
           <th>FEES</th>
           <th>QUALIFICATION</th>
           <th>GENDER</th>

        </tr>
        @foreach(var item in Model)
        {
        <tr>
            <td>@item.Id</td>
             <td>@item.Name</td>
              <td>@item.Age</td>
            <td>@item.Course</td>
            <td>@item.Fees</td>
            <td>@item.Qualification</td>
            <td>@item.Gender</td>
        </tr>
        }
    </table>
</div>
