@model List<Product>

    <h3> Product List </h3>

    <table border="1" cellpadding="10">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
        </tr>

        @foreach(var item in Model)
    {
        <tr>
            <td>@item.ID</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
        </tr>
    }
</table>

<br/>

<a href="@Url.Action("Logout", "Home")">Logout</a>